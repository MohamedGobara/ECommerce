@model IEnumerable<ShoppingCartItem>

    @{
    ViewData["Title"] = "Shopping Cart Summary";
    }

    <div class="row mt-4">
        <div class="col-md-10 offset-md-1">
            <div class="card shadow-sm">
                <div class="card-header bg-dark text-white text-center">
                    <h4 class="mb-0"><i class="fas fa-shopping-cart mr-2"></i> Your Shopping Cart</h4>
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <thead class="thead-light">
                            <tr>
                                <th class="text-center">Quantity</th>
                                <th>Product</th>
                                <th>Price</th>
                                <th>Subtotal</th>
                                <th class="text-right px-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                            <tr>
                                <td class="align-middle text-center">
                                    <span class="badge badge-pill shadow-sm"
                                          style="background-color: #f8f9fa; border: 1px solid #dee2e6; color: #212529; font-weight: bold; padding: 8px 15px;">
                                        @item.Quantity
                                    </span>
                                </td>
                                <td class="align-middle font-weight-bold">@item.Product.Name</td>
                                <td class="align-middle">@item.Product.Price.ToString("c")</td>
                                <td class="align-middle">@((item.Product.Price * item.Quantity).ToString("c"))</td>
                                <td class="align-middle text-right px-4">
                                    <a class="btn btn-outline-danger btn-sm" asp-controller="Orders" asp-action="RemoveitemFromCart" asp-route-id="@item.Product.Id">
                                        <i class="fas fa-minus"></i>
                                    </a>
                                    <a class="btn btn-outline-success btn-sm" asp-controller="Orders" asp-action="AddToCart" asp-route-id="@item.Product.Id">
                                        <i class="fas fa-plus"></i>
                                    </a>
                                </td>
                            </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="3" class="text-right font-weight-bold">Total:</td>
                                <td class="font-weight-bold text-success" colspan="2">
                                    @Model.Sum(x => x.Product.Price * x.Quantity).ToString("c")
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
                <div class="card-footer d-flex justify-content-between">
                    <a class="btn btn-outline-secondary" asp-controller="Products" asp-action="Index">
                        <i class="fas fa-arrow-left"></i> Continue Shopping
                    </a>
                    <a class="btn btn-primary" asp-controller="Orders" asp-action="CompleteOrder">
                        Complete Order <i class="fas fa-credit-card ml-1"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>

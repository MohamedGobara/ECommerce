@model Product



@{
    ViewData["Title"] = "Create Product";
    var AllCategories = new SelectList(ViewBag.Categories, "Id", "Name");

}

<div class="container mt-5">
    @* mt-5 adds top margin to the whole page *@
    <div class="row justify-content-center">
        @* This centers the column horizontally *@

        <div class="col-md-6 shadow p-4 rounded bg-light">
            @* col-md-6 is a better size for a form; shadow and background make it "pop" *@

            <h2 class="text-center mb-4">Add New Product</h2>

            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="mb-3">
                    @* mb-3 adds standard spacing between rows *@
                    <label asp-for="Name" class="form-label font-weight-bold"></label>
                    <input asp-for="Name" value="@Model.Name" class="form-control" placeholder="Enter category name" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Description" class="form-label font-weight-bold"></label>
                    <textarea asp-for="Description" class="form-control" placeholder="Describe the product..." />@Model.Description</textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>


                <div class="mb-4">
                    <label asp-for="Price" class="form-label font-weight-bold"></label>
                    <input asp-for="Price" value="@Model.Price" class="form-control" placeholder="Enter the price" />
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ImageURL" class="form-label font-weight-bold"></label>
                    <input asp-for="ImageURL"value="@Model.ImageURL"  class="form-control" placeholder="Enter Image Name" />
                    <span asp-validation-for="ImageURL" class="text-danger"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="Category" class="form-label font-weight-bold"></label>


                    <select asp-for="CategoryId" asp-items="@AllCategories" class="form-control" autofocus="@Model.CategoryId."></select>
                    <span asp-validation-for="CategoryId" class="text-danger"></span>
                </div>


                <div class="d-flex justify-content-between">
                    @* Flexbox keeps buttons on the same line with space between *@
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="fas fa-arrow-left"></i> Back to List
                    </a>
                    <button type="submit" class="btn btn-success px-4">
                        Save Chnages <i class="fas fa-save ms-1"></i>
                    </button>
                </div>
            </form>

        </div>
    </div>
</div>

@section Scripts{

    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial");}


}

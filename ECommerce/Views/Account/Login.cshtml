@model ECommerce.Data.ViewModel.LoginVM

@{
    ViewData["Title"] = "Login";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">

        <div class="card shadow-lg border-0" style="border-radius:15px;">
            <div class="card-body p-4">

                <h3 class="text-center mb-4 fw-bold">Login</h3>

                <!-- Error Message -->
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger text-center">
                        Invalid email or password
                    </div>
                }

                <form asp-action="Login" asp-validation-summary="All">

                    <div class="mb-3">
                        <label class="form-label" asp-for="EmailAddress"></label>
                        <input class="form-control" asp-for="EmailAddress" placeholder="Enter your email" />
                        <span class="text-danger" asp-validation-for="EmailAddress"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" asp-for="Password"></label>
                        <input class="form-control" asp-for="Password" type="password" placeholder="Enter your password" />
                        <span class="text-danger" asp-validation-for="Password"></span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mt-4">

                        <a class="btn btn-outline-secondary" asp-action="Register">
                            Register
                        </a>

                        <button class="btn btn-login px-4" type="submit">
                            <i class="fas fa-sign-in-alt me-1"></i> Login
                        </button>

                    </div>

                </form>

            </div>
        </div>

    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}